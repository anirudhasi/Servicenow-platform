# ════════════════════════════════════════════════════════════════════════════
# ServiceNow Intelligence Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# ════════════════════════════════════════════════════════════════════════════

# ── Data Source ───────────────────────────────────────────────────────────────
DATA_SOURCE=csv                          # csv | servicenow_api
CSV_PATH=./data/incidents.csv

# ── ServiceNow REST API (activate when DATA_SOURCE=servicenow_api) ─────────
SERVICENOW_INSTANCE=your-instance        # e.g. dev123456.service-now.com
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
CACHE_TTL=300                            # seconds; 0 = disable cache

# ── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ════════════════════════════════════════════════════════════════════════════
# LLM Configuration  (required for M3 LLM hints, M4 routing reasoning, M5 Chatbot)
# ════════════════════════════════════════════════════════════════════════════

# ── Legacy single-key form (backward compatible) ──────────────────────────────
CG_ACCESS_TOKEN=your-capgemini-access-token-here
BASE_URL=https://openai.generative.engine.capgemini.com/v1
LLM_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ── Multi-provider fallback (Provider 1 tried first, then 2, then 3) ─────────

# Provider 1 — Capgemini OpenAI-compatible endpoint (PRIMARY)
PROVIDER_1_NAME=capgemini
PROVIDER_1_BASE_URL=https://openai.generative.engine.capgemini.com/v1
PROVIDER_1_API_KEY=your-cg-access-token-here
PROVIDER_1_MODELS=us.anthropic.claude-sonnet-4-5-20250929-v1:0,us.anthropic.claude-opus-4-5-20250929-v1:0

# Provider 2 — OpenAI (FALLBACK)
PROVIDER_2_NAME=openai
PROVIDER_2_BASE_URL=https://api.openai.com/v1
PROVIDER_2_API_KEY=your-openai-api-key-here
PROVIDER_2_MODELS=gpt-4o,gpt-4-turbo

# Provider 3 — Anthropic native (LAST RESORT)
PROVIDER_3_NAME=anthropic
PROVIDER_3_BASE_URL=https://api.anthropic.com/v1
PROVIDER_3_API_KEY=your-anthropic-api-key-here
PROVIDER_3_MODELS=claude-3-5-sonnet-20241022,claude-3-opus-20240229

# ════════════════════════════════════════════════════════════════════════════
# Email — Microsoft Graph API (O365 / Azure AD)
# Register an app at https://portal.azure.com → Azure AD → App registrations
# Grant Mail.Send (Application permission) + admin consent
# ════════════════════════════════════════════════════════════════════════════
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Email addresses
SMTP_USER=anirudha.si@capgemini.com
IT_EMAIL=anirudha.si@capgemini.com

# Fallback: if Azure Graph API creds are blank, emails save as HTML files locally
